  "requests": [
    {
      "text": "杨广,被骂了一千四百年的暴君。可今天,我要给他翻案。",
      "voice_id": "Chinese (Mandarin)_Reliable_Executive",
      "speed": 1.05,
      "emotion": "neutral"
